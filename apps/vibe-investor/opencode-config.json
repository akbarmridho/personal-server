{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "enabled_providers": ["openai", "opencode", "myprovider"],
  "provider": {
    "myprovider": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "My Custom Provider",
      "options": {
        "baseURL": "http://localhost:4901/v1",
        "apiKey": "secret"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "limit": {
            "context": 400000,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "formatter": false,
  "lsp": false,
  "default_agent": "vibe-investor",
  "instructions": ["{env:OPENCODE_CWD}/memory/MEMORY.md"],
  "share": "disabled",
  "autoupdate": false,
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": ["*"]
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "write": "allow",
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "webfetch": "deny",
    "doom_loop": "allow",
    "external_directory": "allow",
    "todoread": "deny",
    "todowrite": "deny",
    "question": "deny",
    "lsp": "deny"
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "vibe-investor": {
      "description": "IDX investment analyst, portfolio manager, and trading desk powered by the Stock Market 2.0 framework",
      "mode": "all",
      "prompt": "{file:./prompts/vibe-investor/main.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "task": true,
        "skill": true,
        "lsp": false
      },
      "permission": {
        "task": {
          "*": "deny",
          "vibe-investor": "allow"
        }
      }
    }
  },
  "command": {
    "ta": {
      "description": "Technical analysis with WIB trading-session-aware date context (arg1=symbol, remaining args=user intent sentence)",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/ta.md}\n\nCommand input: $ARGUMENTS"
    },
    "desk-check": {
      "description": "Main operator routine for holdings, watchlist, market context, and portfolio discipline with WIB trading-session-aware date context",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/desk-check.md}\n\nCommand input: $ARGUMENTS"
    },
    "deep-review": {
      "description": "Slower full audit of portfolio quality, watchlist hygiene, neglected names, and process quality with WIB trading-session-aware date context",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/deep-review.md}\n\nCommand input: $ARGUMENTS"
    },
    "explore-idea": {
      "description": "Discovery workflow for fresh ideas outside the active operating set plus dormant internal candidates worth revisiting",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/explore-idea.md}\n\nCommand input: $ARGUMENTS"
    },
    "news-digest": {
      "description": "Reading-oriented digest from full memory scope plus all new high-signal documents with WIB trading-session-aware date context",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/news-digest.md}\n\nCommand input: $ARGUMENTS"
    },
    "digest-sync": {
      "description": "Sync thesis/watchlist memory from the latest news digest with WIB trading-session-aware date context",
      "agent": "vibe-investor",
      "template": "{file:./prompts/workflows/digest-sync.md}\n\nCommand input: $ARGUMENTS"
    }
  },
  "mcp": {
    "stock-mcp": {
      "type": "remote",
      "url": "https://kb.akbarmr.dev/mcps/stock/mcp",
      "enabled": true,
      "timeout": 300000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,crawling_exa&exaApiKey={env:EXA_API_KEY}",
      "enabled": true,
      "timeout": 30000
    }
  }
}
