{
  "name": "@personal-server/nutrition-tracker",
  "version": "1.0.0",
  "description": "Personal nutrition tracking Telegram bot with LLM-powered food estimation.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import @dotenvx/dotenvx/config src/index.ts",
    "setup-db": "npx tsx src/scripts/setup-food-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.49.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@t3-oss/env-core": "^0.13.8",
    "ai": "^6.0.175",
    "better-sqlite3": "^12.9.0",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.44.2",
    "grammy": "^1.35.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.7",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.4",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  }
}
