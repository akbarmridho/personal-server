# --- Garmin Connect ---
GARMINCONNECT_EMAIL=your_email@example.com
GARMINCONNECT_BASE64_PASSWORD=your_base64_encoded_password

# --- InfluxDB ---
INFLUXDB_USERNAME=influxdb_user
INFLUXDB_PASSWORD=influxdb_secret_password
INFLUXDB_DATABASE=GarminStats

# --- Ryot ---
RYOT_ADMIN_TOKEN=change_me_to_a_long_random_string
RYOT_DB_NAME=ryot
RYOT_DB_HOST=postgres_main
RYOT_DB_USER=postgres
RYOT_DB_PASSWORD=postgres
RYOT_FRONTEND_URL=http://localhost:8027

# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
